# LLM
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
TRIAGE_LLM_COST_PROFILE=lean
TRIAGE_LANGUAGE=english
TRIAGE_LLM_MODEL=gpt-4o-mini
TRIAGE_OPENAI_MODEL=gpt-4o-mini
TRIAGE_ANTHROPIC_MODEL=claude-3-7-sonnet

# Notifications
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
TRIAGE_NOTIFIER_TARGETS=discord
JIRA_BASE_URL=
JIRA_PROJECT_KEY=
JIRA_ISSUE_TYPE=Bug
JIRA_EMAIL=
JIRA_API_TOKEN=
# Cloud credentials (examples; use provider-native auth in production)
AWS_PROFILE=
GOOGLE_APPLICATION_CREDENTIALS=

# Repository access
GIT_USERNAME=
GIT_TOKEN=
# Optional JSON array or comma/newline-separated list.
# Public repos can be cloned without credentials; private repos require GIT_USERNAME/GIT_TOKEN
# or explicit triage.yaml repos[].auth indirection.
TRIAGE_REPO_URLS=[]

# Scan defaults (optional; allows running `triage scan` with minimal flags)
TRIAGE_SCAN_CLOUD=gcp
TRIAGE_SCAN_RUNTIME=go
TRIAGE_SCAN_SOURCE=gcp-pubsub
TRIAGE_SCAN_PROJECT_ID=gcp-course-2024
TRIAGE_SCAN_SUBSCRIPTION=triage-dev-pull
TRIAGE_SCAN_LOG_FILTER=
TRIAGE_SCAN_LOG_FRESHNESS=30m
TRIAGE_SCAN_PROVIDER=openai
TRIAGE_SCAN_MODEL=
TRIAGE_SCAN_REPO_BRANCH=develop
TRIAGE_SCAN_NOTIFY=true
TRIAGE_SCAN_NOTIFY_TARGETS=discord
